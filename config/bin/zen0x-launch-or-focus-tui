#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like zen0x-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.zen0x.$(basename "$1")"
LAUNCH_COMMAND="zen0x-launch-tui $@"

exec zen0x-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
