{
  "$schema": "https://opencode.ai/theme.json",
  "theme": {
    "primary": {
      "dark": "{{ blue }}",
      "light": "{{ accent }}"
    },
    "secondary": {
      "dark": "{{ purple }}",
      "light": "{{ purple }}"
    },
    "accent": {
      "dark": "{{ cyan }}",
      "light": "{{ cyan }}"
    },
    "error": {
      "dark": "{{ red }}",
      "light": "{{ red }}"
    },
    "warning": {
      "dark": "{{ yellow }}",
      "light": "{{ yellow }}"
    },
    "success": {
      "dark": "{{ green }}",
      "light": "{{ green }}"
    },
    "info": {
      "dark": "{{ blue }}",
      "light": "{{ accent }}"
    },

    "text": {
      "dark": "{{ fg0 }}",
      "light": "{{ bg0 }}"
    },
    "textMuted": {
      "dark": "{{ fg2 }}",
      "light": "{{ fg1 }}"
    },

    "background": {
      "dark": "{{ bg0 }}",
      "light": "{{ bg1 }}"
    },
    "backgroundPanel": {
      "dark": "{{ bg1 }}",
      "light": "{{ bg2 }}"
    },
    "backgroundElement": {
      "dark": "{{ bg2 }}",
      "light": "{{ bg3 }}"
    },

    "border": {
      "dark": "{{ bg3 }}",
      "light": "{{ bg2 }}"
    },
    "borderActive": {
      "dark": "{{ bg4 }}",
      "light": "{{ bg3 }}"
    },
    "borderSubtle": {
      "dark": "{{ bg3 }}",
      "light": "{{ bg2 }}"
    },

    "diffAdded": {
      "dark": "{{ green }}",
      "light": "{{ green }}"
    },
    "diffRemoved": {
      "dark": "{{ red }}",
      "light": "{{ red }}"
    },
    "diffContext": {
      "dark": "{{ fg2 }}",
      "light": "{{ fg2 }}"
    },
    "diffHunkHeader": {
      "dark": "{{ fg1 }}",
      "light": "{{ fg1 }}"
    },
    "diffHighlightAdded": {
      "dark": "{{ green }}",
      "light": "{{ green }}"
    },
    "diffHighlightRemoved": {
      "dark": "{{ red }}",
      "light": "{{ red }}"
    },

    "diffAddedBg": {
      "dark": "{{ bg2 }}",
      "light": "{{ bg1 }}"
    },
    "diffRemovedBg": {
      "dark": "{{ bg2 }}",
      "light": "{{ bg1 }}"
    },
    "diffContextBg": {
      "dark": "{{ bg1 }}",
      "light": "{{ bg2 }}"
    },

    "diffLineNumber": {
      "dark": "{{ fg2 }}",
      "light": "{{ fg1 }}"
    },
    "diffAddedLineNumberBg": {
      "dark": "{{ bg2 }}",
      "light": "{{ bg1 }}"
    },
    "diffRemovedLineNumberBg": {
      "dark": "{{ bg2 }}",
      "light": "{{ bg1 }}"
    },

    "markdownText": {
      "dark": "{{ fg0 }}",
      "light": "{{ bg0 }}"
    },
    "markdownHeading": {
      "dark": "{{ blue }}",
      "light": "{{ accent }}"
    },
    "markdownLink": {
      "dark": "{{ blue }}",
      "light": "{{ blue }}"
    },
    "markdownLinkText": {
      "dark": "{{ cyan }}",
      "light": "{{ cyan }}"
    },
    "markdownCode": {
      "dark": "{{ green }}",
      "light": "{{ green }}"
    },
    "markdownBlockQuote": {
      "dark": "{{ fg2 }}",
      "light": "{{ fg2 }}"
    },
    "markdownEmph": {
      "dark": "{{ yellow }}",
      "light": "{{ yellow }}"
    },
    "markdownStrong": {
      "dark": "{{ yellow }}",
      "light": "{{ yellow }}"
    },
    "markdownHorizontalRule": {
      "dark": "{{ fg2 }}",
      "light": "{{ fg2 }}"
    },
    "markdownListItem": {
      "dark": "{{ blue }}",
      "light": "{{ accent }}"
    },
    "markdownListEnumeration": {
      "dark": "{{ cyan }}",
      "light": "{{ cyan }}"
    },
    "markdownImage": {
      "dark": "{{ blue }}",
      "light": "{{ blue }}"
    },
    "markdownImageText": {
      "dark": "{{ cyan }}",
      "light": "{{ cyan }}"
    },
    "markdownCodeBlock": {
      "dark": "{{ fg0 }}",
      "light": "{{ bg0 }}"
    },

    "syntaxComment": {
      "dark": "{{ fg2 }}",
      "light": "{{ fg2 }}"
    },
    "syntaxKeyword": {
      "dark": "{{ purple }}",
      "light": "{{ purple }}"
    },
    "syntaxFunction": {
      "dark": "{{ blue }}",
      "light": "{{ blue }}"
    },
    "syntaxVariable": {
      "dark": "{{ cyan }}",
      "light": "{{ cyan }}"
    },
    "syntaxString": {
      "dark": "{{ green }}",
      "light": "{{ green }}"
    },
    "syntaxNumber": {
      "dark": "{{ purple }}",
      "light": "{{ purple }}"
    },
    "syntaxType": {
      "dark": "{{ cyan }}",
      "light": "{{ cyan }}"
    },
    "syntaxOperator": {
      "dark": "{{ blue }}",
      "light": "{{ blue }}"
    },
    "syntaxPunctuation": {
      "dark": "{{ fg0 }}",
      "light": "{{ bg0 }}"
    }
  }
}
